# Database
MONGO_URI=mongodb://localhost:27017/vibecoding

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=your-secret-key-change-in-production
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# LLM APIs
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# LLM Configuration (Priority order)
PRIMARY_LLM=anthropic     # Claude 4.5 Sonnet (best quality)
FALLBACK_LLM=gemini       # Gemini 2.0 Flash (fast & cheap)
TERTIARY_LLM=openai       # GPT-4 Turbo (reliable backup)

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
PORT=3001
