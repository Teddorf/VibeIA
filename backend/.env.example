# Server
PORT=3001
NODE_ENV=production

# Database (Railway provides MONGO_URI automatically if you add MongoDB service)
MONGO_URI=mongodb://localhost:27017/vibecoding

# Redis (Railway provides REDIS_URL automatically if you add Redis service)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://your-backend.railway.app/auth/github/callback

# LLM APIs (at least one required)
ANTHROPIC_API_KEY=sk-ant-api...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# LLM Configuration (Priority order)
PRIMARY_LLM=anthropic
FALLBACK_LLM=gemini
TERTIARY_LLM=openai

# Frontend URL (for CORS - update with your Vercel URL)
FRONTEND_URL=https://your-frontend.vercel.app
